# Local environment variables (DO NOT COMMIT)
# Copy this file to .env and fill in your values.
# Better: use GitHub repo Secrets + Variables instead of committing .env.

# Required for any workflow that pushes back to the repo
# (GitHub provides GITHUB_TOKEN automatically — no action needed)

# Optional: webhook for failure alerts
DISCORD_WEBHOOK=

# Optional: webhook for failure alerts (Slack)
SLACK_WEBHOOK=

# Brand customization (set as repo Variables, not secrets)
BRAND_NAME=Local Boutique
CITY=Narowal

# Languages: en, roman, urdu (comma-separated)
LANGUAGES=en,roman
